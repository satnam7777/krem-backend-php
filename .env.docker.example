APP_NAME=Krema
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://demo.localhost

LOG_CHANNEL=stack

DB_CONNECTION=pgsql
DB_HOST=postgres
DB_PORT=5432
DB_DATABASE=krema_central
DB_USERNAME=krema
DB_PASSWORD=krema_pass

# Tenant connection will be filled dynamically; host creds defined here:
TENANT_DB_HOST=postgres
TENANT_DB_PORT=5432
TENANT_DB_USERNAME=krema
TENANT_DB_PASSWORD=krema_pass
TENANT_DB_PREFIX=krema_tenant_

CACHE_DRIVER=redis
QUEUE_CONNECTION=redis
SESSION_DRIVER=file

REDIS_HOST=redis
REDIS_PORT=6379

# Module 11 uploads (if you add it later)
KREMA_UPLOAD_DISK=public
KREMA_UPLOAD_MAX_MB=20
KREMA_PURGE_FILES_AFTER_DAYS=30
KREMA_SIGNED_URL_MINUTES=10

TENANT_MIGRATION_PATH=database/migrations/tenant
